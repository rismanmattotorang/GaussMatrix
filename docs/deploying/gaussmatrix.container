[Container]
Environment=GAUSSMATRIX_SERVER_NAME=your.domain.here GAUSSMATRIX_DATABASE_PATH=/var/lib/gaussmatrix GAUSSMATRIX_PORT=6167 GAUSSMATRIX_MAX_REQUEST_SIZE=20000000 GAUSSMATRIX_ALLOW_REGISTRATION=true GAUSSMATRIX_REGISTRATION_TOKEN=YOUR_TOKEN GAUSSMATRIX_ALLOW_FEDERATION=true GAUSSMATRIX_TRUSTED_SERVERS=["matrix.org"] GAUSSMATRIX_ADDRESS=0.0.0.0 # Add GAUSSMATRIX_CONFIG: '/etc/gaussmatrix.toml' if the config is mapped
Image=docker.io/rismanmattotorang/gaussmatrix:latest
PublishPort=8448:6167
Volume=/path/to/db:/var/lib/gaussmatrix
#Volume=/path/to/gaussmatrix.toml:/etc/gaussmatrix.toml #Uncomment to use the config file

[Service]
Restart=always
