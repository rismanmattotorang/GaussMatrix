#!/bin/sh
set -e

#. /usr/share/debconf/confmodule

GAUSSMATRIX_CONFIG_PATH=/etc/gaussmatrix
GAUSSMATRIX_DATABASE_PATH=/var/lib/gaussmatrix
CONDUIT_DATABASE_PATH_SYMLINK=/var/lib/matrix-conduit
CONDUWUIT_DATABASE_PATH_SYMLINK=/var/lib/conduwuit

case $1 in
  purge)
    # Remove debconf changes from the db
    #db_purge

    # Per https://www.debian.org/doc/debian-policy/ch-files.html#behavior
    # "configuration files must be preserved when the package is removed, and
    #  only deleted when the package is purged."

    #

    if [ -d "$GAUSSMATRIX_CONFIG_PATH" ]; then
      if test -L "$GAUSSMATRIX_CONFIG_PATH"; then
        echo "Deleting gaussmatrix configuration files"
        rm -v -r "$GAUSSMATRIX_CONFIG_PATH"
      fi
    fi

    if [ -d "$GAUSSMATRIX_DATABASE_PATH" ]; then
      if test -L "$GAUSSMATRIX_DATABASE_PATH"; then
        echo "Deleting gaussmatrix database directory"
        rm -r "$GAUSSMATRIX_DATABASE_PATH"
      fi
    fi

    if [ -d "$CONDUIT_DATABASE_PATH_SYMLINK" ]; then
      if test -L "$CONDUIT_DATABASE_SYMLINK"; then
        echo "Removing matrix-conduit symlink"
        rm -r "$CONDUIT_DATABASE_PATH_SYMLINK"
      fi
    fi

    if [ -d "$CONDUWUIT_DATABASE_PATH_SYMLINK" ]; then
      if test -L "$CONDUWUIT_DATABASE_SYMLINK"; then
        echo "Removing conduwuit symlink"
        rm -r "$CONDUWUIT_DATABASE_PATH_SYMLINK"
      fi
    fi
    ;;
esac

#DEBHELPER#
