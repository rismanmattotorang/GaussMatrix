GAUSSMATRIX_SERVER_NAME="your.server.tld"
GAUSSMATRIX_PORT=8008
GAUSSMATRIX_MAX_REQUEST_SIZE=20000000
GAUSSMATRIX_ALLOW_REGISTRATION=true
GAUSSMATRIX_REGISTRATION_TOKEN=<replace with a passphrase or random string>
GAUSSMATRIX_ALLOW_FEDERATION=true
GAUSSMATRIX_TRUSTED_SERVERS=["matrix.org"]
GAUSSMATRIX_LOG=info

#Listen on this host for IPv4 and v6
GAUSSMATRIX_ADDRESS=["0.0.0.0", "::"]

#Tell GaussMatrix to use the user config file 
GAUSSMATRIX_CONFIG=/etc/gaussmatrix.toml

